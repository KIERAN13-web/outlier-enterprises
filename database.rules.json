{
  "rules": {
    ".read": false,
    ".write": false,

    "pendingPayments": {
      ".read": "auth != null && root.child('users').child(auth.uid).child('isAdmin').val() === true",
      ".write": "auth != null && root.child('users').child(auth.uid).child('isAdmin').val() === true",
      ".indexOn": ["checkoutRequestId", "orderTrackingId", "status", "createdAt"]
    },

    "pendingUsers": {
      ".read": "auth != null && root.child('users').child(auth.uid).child('isAdmin').val() === true",
      ".write": "auth != null && root.child('users').child(auth.uid).child('isAdmin').val() === true",
      ".indexOn": ["status", "createdAt"]
    },

    "users": {
      ".indexOn": ["isAdmin", "referralCode"],
      "$uid": {
        ".read": "auth != null && (auth.uid === $uid || root.child('users').child(auth.uid).child('isAdmin').val() === true)",
        ".write": "auth != null && (auth.uid === $uid || root.child('users').child(auth.uid).child('isAdmin').val() === true)",
        "wallet": {
          ".read": "auth != null && (auth.uid === $uid || root.child('users').child(auth.uid).child('isAdmin').val() === true)",
          ".write": "auth != null && (auth.uid === $uid || root.child('users').child(auth.uid).child('isAdmin').val() === true)",
          "transactions": {
            ".read": "auth != null && (auth.uid === $uid || root.child('users').child(auth.uid).child('isAdmin').val() === true)",
            ".write": false
          },
          "withdrawals": {
            ".read": "auth != null && (auth.uid === $uid || root.child('users').child(auth.uid).child('isAdmin').val() === true)",
            ".write": "auth != null && (auth.uid === $uid || root.child('users').child(auth.uid).child('isAdmin').val() === true)"
          }
        },
        "notifications": {
          ".read": "auth != null && auth.uid === $uid",
          ".write": false
        }
      }
    },

    "accountPool": {
      ".read": "auth != null",
      ".write": "auth != null"
    },

    "outlierBooks": {
      ".read": "auth != null",
      ".write": "auth != null"
    }
  }
}
