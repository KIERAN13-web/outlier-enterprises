# Server
PORT=4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# Firebase Admin
# Provide a service account JSON file path OR use GOOGLE_APPLICATION_CREDENTIALS.
FIREBASE_SERVICE_ACCOUNT_PATH=./serviceAccountKey.json
# OR:
# GOOGLE_APPLICATION_CREDENTIALS=./serviceAccountKey.json

# Payment (M-Pesa) - placeholders
M_PESA_ENV=sandbox # sandbox or production
M_PESA_CONSUMER_KEY=your_consumer_key
M_PESA_CONSUMER_SECRET=your_consumer_secret
M_PESA_SHORT_CODE=174379
M_PESA_PASSKEY=your_passkey
M_PESA_CALLBACK_URL=http://localhost:4000/api/payments/mpesa/webhook
M_PESA_CALLBACK_USERNAME=optional
M_PESA_CALLBACK_PASSWORD=optional

# Pesapal callbacks
PESAPAL_ENV=sandbox # sandbox or production
PESAPAL_CONSUMER_KEY=your_pesapal_api_key
PESAPAL_CONSUMER_SECRET=your_pesapal_api_secret
PESAPAL_CALLBACK_URL=https://your-backend-url/api/payments/pesapal/webhook
PESAPAL_IPN_ID=your_pesapal_ipn_id
PESAPAL_WEBHOOK_SECRET=your_pesapal_webhook_secret

# Firestore
FIREBASE_PROJECT_ID=your_project_id

