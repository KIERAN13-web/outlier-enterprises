# Production Backend Environment Variables for Railway

PORT=3000
NODE_ENV=production

# CORS Configuration - Your GitHub Pages frontend URL
CORS_ORIGIN=https://kieran13-web.github.io/outlier-enterprises

# Firebase Admin SDK - Use your actual Firebase credentials
FIREBASE_SERVICE_ACCOUNT_PATH=./serviceAccountKey.json
FIREBASE_PROJECT_ID=outlier-enterprise
FIREBASE_DATABASE_URL=https://outlier-enterprise-default-rtdb.asia-southeast1.firebasedatabase.app
